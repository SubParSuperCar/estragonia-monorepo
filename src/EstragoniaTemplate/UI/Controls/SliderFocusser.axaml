<UserControl
    x:Name="root"
    Focusable="True"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Class="Template.UI.Controls.SliderFocusser">

    <ContentControl Name="sliderContentControl"
                    XYFocus.NavigationModes="{Binding #root.XYFocusMode}"
                    Content="{Binding #root.Slider}" />
</UserControl>
