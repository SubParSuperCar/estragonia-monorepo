<UserControl
	x:Name="Root"
	Focusable="True"
	xmlns="https://github.com/avaloniaui"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	x:Class="GameTemplate.UI.Controls.SliderFocusser">

	<ContentControl Name="SliderContentControl"
	                XYFocus.NavigationModes="{Binding #Root.XyFocusMode}"
	                Content="{Binding #Root.Slider}" />
</UserControl>
