<UserControl
	xmlns="https://github.com/avaloniaui"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:vm="using:GameTemplate.UI.ViewModels"
	xmlns:controls="using:GameTemplate.UI.Controls"
	mc:Ignorable="d" d:DesignWidth="960" d:DesignHeight="540"
	x:Class="GameTemplate.UI.Views.GameView"
	x:DataType="vm:GameViewModel">

	<Design.DataContext>
		<vm:GameViewModel />
	</Design.DataContext>

	<StackPanel HorizontalAlignment="Center"
	            VerticalAlignment="Center"
	            Spacing="10">
		<TextBlock>
			This View only exists to test the <Bold>escape menu</Bold> (go ahead, press escape).
		</TextBlock>
		<controls:AudioButton Name="InitialFocus0" Command="{Binding CloseCommand}">
			Main Menu
		</controls:AudioButton>
	</StackPanel>
</UserControl>
